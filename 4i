print("Tiempo, ingresa los numeros en orden.")

gano = 1
for i in range(cantidad):
    print("Posicion:")
    print(i)
    respuesta = int(input())
    
    if respuesta != numeros[i]:
        gano = 0
        break

if gano == 1:
    print("Ganaste")
else:
    print("Perdiste")
